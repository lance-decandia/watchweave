{
  "info": {
    "name": "WatchWeave API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://watchweave-alb-2123412938.us-east-1.elb.amazonaws.com:3000" },
    { "key": "token", "value": "" },
    { "key": "testAnimeId", "value": "1735" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
          "pm.test('Service is healthy', function() { var json = pm.response.json(); pm.expect(json.status).to.eql('healthy'); });"
        ]}
      }]
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/register",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"testuser_{{$timestamp}}\",\"email\":\"test_{{$timestamp}}@test.com\",\"password\":\"Test1234!\"}" }
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 201', function() { pm.response.to.have.status(201); });",
          "pm.test('Returns token', function() { var json = pm.response.json(); pm.expect(json.token).to.exist; pm.collectionVariables.set('token', json.token); });"
        ]}
      }]
    },
    {
      "name": "Login User",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/login",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"email\":\"lance@daemonslayer.com\",\"password\":\"Hockey17Devils\"}" }
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
          "pm.test('Returns token', function() { var json = pm.response.json(); pm.expect(json.token).to.exist; pm.collectionVariables.set('token', json.token); });"
        ]}
      }]
    },
    {
      "name": "Search Anime",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/anime/search?q=naruto&page=1"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
          "pm.test('Returns data array', function() { var json = pm.response.json(); pm.expect(json.data).to.be.an('array'); });"
        ]}
      }]
    },
    {
      "name": "Get Anime by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/anime/20"
      },
      "event": [{
        "listen": "prerequest",
        "script": { "exec": ["setTimeout(function(){}, 2000);"] }
      },
      {
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200 or 429', function() { pm.expect(pm.response.code).to.be.oneOf([200, 429]); });",
          "if(pm.response.code === 200) { pm.test('Returns anime data', function() { var json = pm.response.json(); pm.expect(json.data).to.exist; }); }"
        ]}
      }]
    },
    {
      "name": "Get Watchlist",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/watchlist",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      },
      "event": [{
        "listen": "prerequest",
        "script": { "exec": ["setTimeout(function(){}, 2000);"] }
      },
      {
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200 or 429', function() { pm.expect(pm.response.code).to.be.oneOf([200, 429]); });",
          "if(pm.response.code === 200) { pm.test('Returns array', function() { pm.expect(pm.response.json()).to.be.an('array'); }); }"
        ]}
      }]
    },
    {
      "name": "Add to Watchlist",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/watchlist",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"anime_id\":{{testAnimeId}},\"anime_title\":\"Naruto Test\",\"anime_image\":\"https://example.com/img.jpg\",\"status\":\"plan_to_watch\",\"episodes_watched\":0,\"total_episodes\":220}" }
      },
      "event": [{
        "listen": "prerequest",
        "script": { "exec": ["setTimeout(function(){}, 2000);"] }
      },
      {
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 201 or 429', function() { pm.expect(pm.response.code).to.be.oneOf([201, 409, 429]); });"
        ]}
      }]
    },
    {
      "name": "Unauthorized Access",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/watchlist"
      },
      "event": [{
        "listen": "prerequest",
        "script": { "exec": ["setTimeout(function(){}, 2000);"] }
      },
      {
        "listen": "test",
        "script": { "exec": [
          "pm.test('Returns 401 or 429', function() { pm.expect(pm.response.code).to.be.oneOf([401, 429]); });"
        ]}
      }]
    },
    {
      "name": "Cleanup - Remove Test Watchlist Entry",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/watchlist/{{testAnimeId}}",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Cleanup successful', function() { pm.expect(pm.response.code).to.be.oneOf([200, 404, 429]); });"
        ]}
      }]
    }
  ]
}
